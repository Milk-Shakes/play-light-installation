; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Play-Light-Installation"
run/main_scene="uid://dijcocah11hrg"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://icon.svg"

[debug]

settings/stdout/print_fps=true

[display]

window/size/viewport_width=512
window/size/viewport_height=512
window/stretch/aspect="ignore"
window/vsync/vsync_mode=0

[dotnet]

project/assembly_name="Play-Light-Installation"

[editor_plugins]

enabled=PackedStringArray("res://addons/gdserial/plugin.cfg")

[network]

limits/packet_peer_stream/max_buffer_po2=4653
limits/webrtc/max_channel_in_buffer_kb=2066

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

rendering_device/driver.windows="d3d12"
environment/defaults/default_clear_color=Color(0, 0, 0, 1)
